    62.08,                   !- Latitude {deg}
    129.75,                  !- Longitude {deg}
    9,                       !- Time Zone {hr}
    103;                     !- Elevation {m}


!-   ===========  ALL OBJECTS IN CLASS: RUNPERIOD ===========

